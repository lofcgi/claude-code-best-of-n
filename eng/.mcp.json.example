{
  "mcpServers": {
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": ""
      }
    },
    "vercel": {
      "type": "sse",
      "url": "https://mcp.vercel.com"
    },
    "github": {
      "type": "sse",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_TOKEN}"
      }
    },
    "v0": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/v0-mcp"]
    },
    "21st-dev-magic": {
      "command": "npx",
      "args": ["-y", "@21st-dev/magic-mcp"],
      "env": {
        "TWENTY_FIRST_API_KEY": ""
      }
    },
    "design-inspiration": {
      "command": "npx",
      "args": ["-y", "design-inspiration-mcp"],
      "env": {
        "SERPER_API_KEY": ""
      }
    }
  }
}
